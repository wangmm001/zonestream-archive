{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/zonestream/confirmed_newly_registered_domain.json",
  "title": "confirmed_newly_registered_domain (DarkDNS-validated)",
  "description": "Has a confidence score; observed fields domain, cert_index, ct_name, timestamp, confidence.",
  "type": "object",
  "required": ["domain", "timestamp"],
  "properties": {
    "domain":     {"type": "string", "minLength": 1},
    "cert_index": {"type": "integer", "minimum": 0},
    "ct_name":    {"type": "string"},
    "timestamp":  {"type": "integer", "minimum": 0},
    "confidence": {"type": "number"}
  },
  "additionalProperties": true
}
